# ChronoFlow API (server-side only — never expose keys with NEXT_PUBLIC_)
CHRONOFLOW_API_BASE_URL=http://localhost:5000
CHRONOFLOW_API_KEY=

# SignalForge API — trace + analytics (optional)
SIGNALFORGE_API_BASE_URL=
# Bearer JWT for GET /alerts/metrics and authenticated alert reads
SIGNALFORGE_API_TOKEN=

# A.I.L. — reserved for future read-only endpoints (advisory snapshots come from ChronoFlow today)
AIL_API_BASE_URL=
AIL_API_KEY=
